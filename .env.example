NODE_ENV=development
PORT=3000
APP_DOMAIN=localhost
# Optional: canonical base for newsletter links (default: https://{username}.{APP_DOMAIN})
# APP_PUBLIC_BASE_URL=https://yourusername.localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grizzly
JWT_SECRET=replace-with-at-least-16-characters
JWT_EXPIRES_IN=1d

# Redis (BullMQ email queue; default 127.0.0.1:6379)
# REDIS_URL=redis://127.0.0.1:6379

# Local uploads (served at /uploads)
# UPLOAD_DIR=./uploads/public

# CORS for a future SPA dashboard (comma-separated origins)
# CORS_ORIGIN=http://localhost:5173

# SMTP (optional; without it emails are skipped with a log line)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Grizzly <noreply@example.com>"
