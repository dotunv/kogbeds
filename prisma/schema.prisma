generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NewsletterSubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum CommentModerationStatus {
  PENDING
  APPROVED
  SPAM
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  blog          Blog?
  postRevisions PostRevision[]
}

model Blog {
  id                      String   @id @default(cuid())
  ownerId                 String   @unique
  title                   String
  description             String?
  customCss               String?
  isPublic                Boolean  @default(true)
  customDomain            String?  @unique
  customDomainVerifyToken String?
  customDomainVerifiedAt  DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  owner                   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  posts                   Post[]
  assets                  Asset[]
  newsletterSubscribers   NewsletterSubscriber[]
  pageViewRollups         PageViewRollup[]
}

model Asset {
  id        String   @id @default(cuid())
  blogId    String
  filename  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId])
}

model Post {
  id                 String   @id @default(cuid())
  blogId             String
  title              String
  slug               String
  contentMarkdown    String?
  blocks             Json?
  blockSchemaVersion Int      @default(1)
  contentHtml        String?
  excerpt            String?
  searchableText     String?
  featuredImageUrl   String?
  isPublished        Boolean  @default(false)
  publishedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  blog               Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  comments           Comment[]
  revisions          PostRevision[]
  tags               PostTag[]

  @@unique([blogId, slug])
  @@index([blogId, isPublished])
}

model Tag {
  id    String    @id @default(cuid())
  slug  String    @unique
  name  String
  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model NewsletterSubscriber {
  id           String                     @id @default(cuid())
  blogId       String
  email        String
  status       NewsletterSubscriberStatus @default(PENDING)
  confirmToken String                     @unique
  unsubToken   String                     @unique
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  blog         Blog                       @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, email])
  @@index([blogId])
}

model Comment {
  id          String                  @id @default(cuid())
  postId      String
  authorName  String?
  authorEmail String?
  body        String
  status      CommentModerationStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  post        Post                    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, status])
}

model PostRevision {
  id                 String   @id @default(cuid())
  postId             String
  contentMarkdown    String?
  blocks             Json?
  blockSchemaVersion Int      @default(1)
  contentHtml        String?
  excerpt            String?
  searchableText     String?
  createdByUserId    String?
  createdAt          DateTime @default(now())
  post               Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdBy          User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([postId, createdAt])
}

model PageViewRollup {
  id     String   @id @default(cuid())
  blogId String
  /// Empty string when the view is for the blog home (not a specific post).
  postId String   @default("")
  day    DateTime @db.Date
  views  Int      @default(0)
  blog   Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, postId, day])
  @@index([blogId])
}
